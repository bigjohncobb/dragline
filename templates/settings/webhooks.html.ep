% layout 'default';
% title 'Webhook Settings — Dragline';
% my $configs = stash('configs') // [];

<div class="page-header">
  <h1>Webhook Settings</h1>
</div>

<h2>Your Webhooks</h2>
% if (!@$configs) {
<p class="empty-state">No webhook configurations yet.</p>
% } else {
<table class="table">
  <thead>
    <tr>
      <th>URL</th>
      <th>Active</th>
      <th>Deliveries</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    % for my $cfg (@$configs) {
    <tr>
      <td><%= $cfg->{url} %></td>
      <td><%= $cfg->{is_active} ? 'Yes' : 'No' %></td>
      <td><%= $cfg->{delivery_count} %></td>
      <td>
        <form method="post" action="/settings/webhooks/<%= $cfg->{id} %>/delete" class="inline-form" onsubmit="return confirm('Delete this webhook?')">
          <input type="hidden" name="_csrf_token" value="<%= csrf_token %>">
          <button type="submit" class="btn btn-sm btn-danger">Delete</button>
        </form>
      </td>
    </tr>
    % }
  </tbody>
</table>
% }

<h2>Add Webhook</h2>
<form method="post" action="/settings/webhooks" class="form-stacked">
  <input type="hidden" name="_csrf_token" value="<%= csrf_token %>">
  <label>URL</label>
  <input type="url" name="url" required class="input-text">
  <label>Secret (optional)</label>
  <input type="text" name="secret" class="input-text">
  <label>Event Types (JSON array, default [])</label>
  <input type="text" name="event_types" value='[]' class="input-text">
  <label>Target ID (optional)</label>
  <input type="text" name="target_id" placeholder="Target UUID" class="input-text">
  <button type="submit" class="btn btn-primary">Add Webhook</button>
</form>
