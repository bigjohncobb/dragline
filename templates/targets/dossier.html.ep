% layout 'default';
% my $t = stash('target');
% title 'Dossier — ' . $t->{canonical_name} . ' — Dragline';
% my $dossier  = stash('dossier');
% my $sections = stash('sections') // [];
% my $progress = stash('progress');
% my $versions = stash('versions') // [];
% my $viewing_version = stash('viewing_version');
% my $snapshot = stash('snapshot') // [];

<div class="page-header">
  <h1><a href="/targets/<%= $t->{id} %>"><%= $t->{canonical_name} %></a> — Dossier</h1>
</div>

% if ($viewing_version) {
<div class="status-banner">
  <p><strong>Viewing version <%= $viewing_version->{version_number} %></strong>
    &mdash; created <%= substr($viewing_version->{created_at}, 0, 16) %></p>
  <form method="post" action="/targets/<%= $t->{id} %>/dossier/versions/<%= $viewing_version->{id} %>/restore" class="inline-form"
        onsubmit="return confirm('Restore this version? Current dossier sections will be replaced.')">
    <input type="hidden" name="_csrf_token" value="<%= csrf_token %>">
    <button type="submit" class="btn btn-primary btn-sm">Restore this version</button>
  </form>
  <a href="/targets/<%= $t->{id} %>/dossier" class="btn btn-secondary btn-sm">Back to current</a>
</div>

% my @section_names = (
%   'Identity and Overview', 'Key People', 'Organisational Structure',
%   'Operational Profile', 'Document Archive', 'Event Timeline',
%   'Media and Sentiment', 'Risk and Flags', 'Financial Instruments',
%   'Forward Assessment'
% );
% my %snap_by_num = map { $_->{section_number} => $_ } @$snapshot;
<div class="dossier-sections">
% for my $num (1..10) {
%   my $sec = $snap_by_num{$num};
%   my $name = $sec ? $sec->{section_name} : $section_names[$num-1];
%   my $body = $sec ? ($sec->{content} // '') : '';
  <details class="dossier-section" id="section-<%= $num %>">
    <summary class="section-summary"><span class="section-number"><%= $num %>.</span> <%= $name %></summary>
    <div class="section-body">
    % if ($body) {
      <pre class="section-content"><%= $body %></pre>
      % if ($sec->{model_used}) {
      <p class="section-meta">Generated by: <%= $sec->{model_used} %></p>
      % }
    % } else {
      <p class="empty-state-sm">Section not generated.</p>
    % }
    </div>
  </details>
% }
</div>

% } elsif (stash('no_dossier')) {
<p class="empty-state">No dossier yet for this target.</p>
<form method="post" action="/targets/<%= $t->{id} %>/dossier/generate" class="inline-form">
  <input type="hidden" name="_csrf_token" value="<%= csrf_token %>">
  <button type="submit" class="btn btn-primary">Generate Dossier</button>
</form>

% } elsif ($dossier->{status} eq 'generating') {
<meta http-equiv="refresh" content="10">
<div class="status-banner status-generating">
  <p>Dossier generation in progress…</p>
  % if (defined $progress) {
  <p class="progress-note"><%= $progress %> of 10 sections complete.</p>
  % }
  <form method="post" action="/targets/<%= $t->{id} %>/dossier/cancel" class="inline-form" style="margin-top:0.5rem">
    <input type="hidden" name="_csrf_token" value="<%= csrf_token %>">
    <button type="submit" class="btn btn-danger btn-sm">Cancel generation</button>
  </form>
</div>

% } elsif ($dossier->{status} eq 'failed') {
<div class="status-banner status-error">
  <p>Dossier generation failed. The job may have encountered an LLM error or timed out.</p>
  <form method="post" action="/targets/<%= $t->{id} %>/dossier/generate" class="inline-form" style="margin-top:0.5rem">
    <input type="hidden" name="_csrf_token" value="<%= csrf_token %>">
    <button type="submit" class="btn btn-primary btn-sm">Retry Generation</button>
  </form>
</div>

% } else {
% my $status = $dossier->{status};

% if ($status eq 'stale') {
<div class="status-banner status-stale">
  <span class="badge badge-warning">Stale</span>
  <span>New content has been added since this dossier was generated.</span>
</div>
% }

<div class="dossier-header">
  <span class="dossier-meta">Generated: <%= substr($dossier->{generated_at} // 'unknown', 0, 16) %></span>
  <form method="post" action="/targets/<%= $t->{id} %>/dossier/generate" class="inline-form">
    <input type="hidden" name="_csrf_token" value="<%= csrf_token %>">
    <button type="submit" class="btn btn-secondary btn-sm">Regenerate</button>
  </form>
  <a href="/targets/<%= $t->{id} %>/dossier/export?format=json" class="btn btn-secondary btn-sm">Export JSON</a>
  <a href="/targets/<%= $t->{id} %>/dossier/export?format=txt" class="btn btn-secondary btn-sm">Export TXT</a>
</div>

% my @section_names = (
%   'Identity and Overview', 'Key People', 'Organisational Structure',
%   'Operational Profile', 'Document Archive', 'Event Timeline',
%   'Media and Sentiment', 'Risk and Flags', 'Financial Instruments',
%   'Forward Assessment'
% );
% my %sec_by_num = map { $_->{section_number} => $_ } @$sections;

<div class="dossier-sections">
% for my $num (1..10) {
%   my $sec = $sec_by_num{$num};
%   my $name = $sec ? $sec->{section_name} : $section_names[$num-1];
%   my $body = $sec ? ($sec->{content} // '') : '';
  <details class="dossier-section" id="section-<%= $num %>">
    <summary class="section-summary"><span class="section-number"><%= $num %>.</span> <%= $name %></summary>
    <div class="section-body">
    % if ($body) {
      <pre class="section-content"><%= $body %></pre>
      % if ($sec->{model_used}) {
      <p class="section-meta">Generated by: <%= $sec->{model_used} %></p>
      % }
    % } else {
      <p class="empty-state-sm">Section not generated.</p>
    % }
    </div>
  </details>
% }
</div>

% if (@$versions) {
<div class="detail-section">
  <h2>Version History</h2>
  <table class="data-table">
    <thead>
      <tr><th>Version</th><th>Created</th><th>Created by</th><th></th></tr>
    </thead>
    <tbody>
    % for my $v (@$versions) {
      <tr>
        <td>Version <%= $v->{version_number} %></td>
        <td><%= substr($v->{created_at}, 0, 16) %></td>
        <td><%= $v->{created_by} // '' %></td>
        <td class="td-action">
          <a href="/targets/<%= $t->{id} %>/dossier/versions/<%= $v->{id} %>" class="btn btn-xs btn-secondary">View</a>
        </td>
      </tr>
    % }
    </tbody>
  </table>
</div>
% }
% }
