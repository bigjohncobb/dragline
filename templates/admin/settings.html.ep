% layout 'default';
% title 'Settings — Admin — Dragline';
% my $s = stash('settings') // {};

<div class="page-header">
  <h1>Settings</h1>
</div>

<form method="post" action="/admin/settings" class="edit-form">
  <input type="hidden" name="_csrf_token" value="<%= csrf_token %>">

  <fieldset class="settings-group">
    <legend>AI Providers</legend>

    <div class="field">
      <label for="anthropic_api_key">Anthropic API key</label>
      <input type="password" id="anthropic_api_key" name="anthropic_api_key"
             value="<%= $s->{anthropic_api_key}{value} // '' %>"
             autocomplete="off" placeholder="Paste new value to update">
      <span class="field-hint">Used for forward_assessment and high-quality synthesis.</span>
    </div>

    <div class="field">
      <label for="alibaba_api_key">Alibaba (DashScope) API key</label>
      <input type="password" id="alibaba_api_key" name="alibaba_api_key"
             value="<%= $s->{alibaba_api_key}{value} // '' %>"
             autocomplete="off" placeholder="Paste new value to update">
      <span class="field-hint">Used for Qwen LLM and text-embedding-v4 embeddings.</span>
    </div>

    <div class="field">
      <label for="qwen_api_key">Qwen API key</label>
      <input type="password" id="qwen_api_key" name="qwen_api_key"
             value="<%= $s->{qwen_api_key}{value} // '' %>"
             autocomplete="off" placeholder="Paste new value to update">
      <span class="field-hint">Alternative Qwen key (separate from Alibaba if needed).</span>
    </div>

    <div class="field">
      <label for="ollama_base_url">Ollama base URL</label>
      <input type="text" id="ollama_base_url" name="ollama_base_url"
             value="<%= $s->{ollama_base_url}{value} // 'http://localhost:11434' %>">
      <span class="field-hint">Used in airgap mode. Default: http://localhost:11434</span>
    </div>

    <div class="field">
      <label for="default_embed_model">Default embed model</label>
      <input type="text" id="default_embed_model" name="default_embed_model"
             value="<%= $s->{default_embed_model}{value} // 'text-embedding-v4' %>">
    </div>
  </fieldset>

  <fieldset class="settings-group">
    <legend>Data Sources</legend>

    <div class="field">
      <label for="brave_api_key">Brave Search API key</label>
      <input type="password" id="brave_api_key" name="brave_api_key"
             value="<%= $s->{brave_api_key}{value} // '' %>"
             autocomplete="off" placeholder="Paste new value to update">
      <span class="field-hint">Used for target discovery via Brave web search.</span>
    </div>

    <div class="field">
      <label for="forge_api_url">Forge API URL</label>
      <input type="text" id="forge_api_url" name="forge_api_url"
             value="<%= $s->{forge_api_url}{value} // '' %>"
             placeholder="https://forge.example.com/api">
    </div>

    <div class="field">
      <label for="forge_api_key">Forge API key</label>
      <input type="password" id="forge_api_key" name="forge_api_key"
             value="<%= $s->{forge_api_key}{value} // '' %>"
             autocomplete="off" placeholder="Paste new value to update">
    </div>
  </fieldset>

  <fieldset class="settings-group">
    <legend>Services</legend>

    <div class="field">
      <label for="crawl_service_url">Crawl service URL</label>
      <input type="text" id="crawl_service_url" name="crawl_service_url"
             value="<%= $s->{crawl_service_url}{value} // 'http://localhost:3002' %>">
      <span class="field-hint">External JS-rendering crawl service. Default: http://localhost:3002</span>
    </div>

    <div class="field">
      <label for="r_service_url">R service URL</label>
      <input type="text" id="r_service_url" name="r_service_url"
             value="<%= $s->{r_service_url}{value} // 'http://localhost:3003' %>">
      <span class="field-hint">Statistical scoring and gap detection service. Default: http://localhost:3003</span>
    </div>

    <div class="field">
      <label for="crawl_content_threshold">Crawl content threshold <span class="hint">(words)</span></label>
      <input type="number" id="crawl_content_threshold" name="crawl_content_threshold"
             value="<%= $s->{crawl_content_threshold}{value} // '500' %>"
             min="0" class="input-sm">
      <span class="field-hint">Pages with fewer words than this are flagged as potentially JS-heavy.</span>
    </div>
  </fieldset>

  <fieldset class="settings-group">
    <legend>Adversarial Checks</legend>

    <div class="field">
      <label for="adversarial_check_enabled">Enable adversarial checks</label>
      <select id="adversarial_check_enabled" name="adversarial_check_enabled" class="select-sm">
        <option value="0" <%= ($s->{adversarial_check_enabled}{value} // '0') eq '0' ? 'selected' : '' %>>Disabled</option>
        <option value="1" <%= ($s->{adversarial_check_enabled}{value} // '0') eq '1' ? 'selected' : '' %>>Enabled</option>
      </select>
      <span class="field-hint">Cross-validate dossier sections with a different LLM.</span>
    </div>

    <div class="field">
      <label for="adversarial_check_sample_rate">Sample rate <span class="hint">(%)</span></label>
      <input type="number" id="adversarial_check_sample_rate" name="adversarial_check_sample_rate"
             value="<%= $s->{adversarial_check_sample_rate}{value} // '10' %>"
             min="1" max="100" class="input-sm">
    </div>
  </fieldset>

  <fieldset class="settings-group">
    <legend>Backup</legend>

    <div class="field">
      <label for="backup_enabled">Enable scheduled backups</label>
      <select id="backup_enabled" name="backup_enabled" class="select-sm">
        <option value="0" <%= ($s->{backup_enabled}{value} // '0') eq '0' ? 'selected' : '' %>>Disabled</option>
        <option value="1" <%= ($s->{backup_enabled}{value} // '0') eq '1' ? 'selected' : '' %>>Enabled</option>
      </select>
    </div>

    <div class="field">
      <label for="backup_schedule">Backup schedule</label>
      <select id="backup_schedule" name="backup_schedule" class="select-sm">
        <option value="daily" <%= ($s->{backup_schedule}{value} // 'daily') eq 'daily' ? 'selected' : '' %>>Daily</option>
        <option value="hourly" <%= ($s->{backup_schedule}{value} // 'daily') eq 'hourly' ? 'selected' : '' %>>Hourly</option>
      </select>
    </div>

    <div class="field">
      <label for="backup_s3_endpoint">S3 endpoint</label>
      <input type="text" id="backup_s3_endpoint" name="backup_s3_endpoint"
             value="<%= $s->{backup_s3_endpoint}{value} // '' %>"
             placeholder="https://s3.example.com">
    </div>

    <div class="field">
      <label for="backup_s3_bucket">S3 bucket</label>
      <input type="text" id="backup_s3_bucket" name="backup_s3_bucket"
             value="<%= $s->{backup_s3_bucket}{value} // '' %>">
    </div>

    <div class="field">
      <label for="backup_s3_access_key">S3 access key</label>
      <input type="password" id="backup_s3_access_key" name="backup_s3_access_key"
             value="<%= $s->{backup_s3_access_key}{value} // '' %>"
             autocomplete="off" placeholder="Paste new value to update">
    </div>

    <div class="field">
      <label for="backup_s3_secret_key">S3 secret key</label>
      <input type="password" id="backup_s3_secret_key" name="backup_s3_secret_key"
             value="<%= $s->{backup_s3_secret_key}{value} // '' %>"
             autocomplete="off" placeholder="Paste new value to update">
    </div>

    <div class="field">
      <label for="backup_retention_days">Retention <span class="hint">(days)</span></label>
      <input type="number" id="backup_retention_days" name="backup_retention_days"
             value="<%= $s->{backup_retention_days}{value} // '30' %>"
             min="1" class="input-sm">
    </div>
  </fieldset>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">Save settings</button>
  </div>
</form>
